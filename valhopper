#!/usr/bin/env python3
"""ValHopper CLI wrapper."""

import os
import sys

# Prevent bittensor from parsing CLI args - MUST be set before importing bittensor
os.environ['BT_NO_PARSE_CLI_ARGS'] = '1'

# Add src to path if running from source
src_path = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'src')
if os.path.exists(src_path):
    sys.path.insert(0, src_path)

from valhopper.valhopper_cli import cli

if __name__ == '__main__':
    cli()
